{
  "name": "rambutan",
  "private": true,
  "scripts": {
    "dev:client": "pnpm --dir client dev",
    "dev:server": "pnpm --dir server dev",
    "migrate": "pnpm --dir server migrate",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css}": "prettier --write",
    "client/**/*.{js,jsx,ts,tsx}": "pnpm --dir client exec eslint --fix"
  }
}
