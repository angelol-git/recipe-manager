{
  "name": "rambutan",
  "private": true,
  "scripts": {
    "dev:client": "pnpm --dir client dev",
    "dev:server": "pnpm --dir server dev",
    "migrate": "pnpm --dir server migrate",
    "build": "pnpm -r build",
    "lint": "pnpm lint:client && pnpm lint:server",
    "lint:client": "pnpm --dir client lint",
    "lint:server": "./client/node_modules/.bin/eslint ./server",
    "test": "pnpm -r test",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.61.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css}": "prettier --write",
    "client/**/*.{js,jsx,ts,tsx}": "pnpm --dir client exec eslint --fix",
    "server/**/*.{js,ts}": "./client/node_modules/.bin/eslint --fix"
  }
}
